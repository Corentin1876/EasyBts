<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    {# Pages principales #}
    <url>
        <loc>{{ url('app_home') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>1.0</priority>
    </url>
    
    <url>
        <loc>{{ url('app_inscription') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.9</priority>
    </url>
    
    <url>
        <loc>{{ url('app_contact') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.7</priority>
    </url>
    
    {# Formations BTS #}
    <url>
        <loc>{{ url('app_bts_liste') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.9</priority>
    </url>
    
    <url>
        <loc>{{ url('app_formations') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.8</priority>
    </url>
    
    {% for specialisation in specialisations %}
    <url>
        <loc>{{ url('app_specialisation_detail', {'id': specialisation.id}) }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.7</priority>
    </url>
    {% endfor %}
    
    {# Établissements #}
    <url>
        <loc>{{ url('app_etablissements') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.7</priority>
    </url>
    
    {# Ressources et aide #}
    <url>
        <loc>{{ url('app_guide') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.6</priority>
    </url>
    
    <url>
        <loc>{{ url('app_faq') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.6</priority>
    </url>
    
    <url>
        <loc>{{ url('app_calendrier') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.6</priority>
    </url>
    
    <url>
        <loc>{{ url('app_aide_technique') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.5</priority>
    </url>
    
    {# Informations légales #}
    <url>
        <loc>{{ url('app_sitemap') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.4</priority>
    </url>
    
    <url>
        <loc>{{ url('app_legal') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.3</priority>
    </url>
    
    <url>
        <loc>{{ url('app_privacy') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.3</priority>
    </url>
    
    <url>
        <loc>{{ url('app_accessibility') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.3</priority>
    </url>
    
    <url>
        <loc>{{ url('app_cookies') }}</loc>
        <lastmod>{{ "now"|date('Y-m-d') }}</lastmod>
        <changefreq>yearly</changefreq>
        <priority>0.2</priority>
    </url>
</urlset>
